rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /approved_memories/{memoryId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'nickname', 'story', 'submittedAt'])
        && request.resource.data.name is string
        && request.resource.data.nickname is string
        && request.resource.data.story is string
        && request.resource.data.submittedAt is timestamp
        && request.resource.data.story.size() <= 2500;
      allow update, delete: if false;
    }
  }
}
